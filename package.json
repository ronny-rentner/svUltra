{
  "name": "svultra",
  "version": "0.0.1-alpha",
  "description": "Svelte 5 preprocessors for consistent component styling and syntax sugar",
  "type": "module",
  "main": "index.js",
  "imports": {
    "#kit/*": "./src/kit/*"
  },
  "exports": {
    ".":                  "./index.js",
    "./snippet":          "./src/snippet.svelte.js",
    "./kit/actions":      "./src/kit/actions/index.js",
    "./kit/components":   "./src/kit/components/index.js",
    "./kit/components/*": "./src/kit/components/*",
    "./kit/assets/icons": "./src/kit/assets/icons/index.js",
    "./kit/assets/*":     "./src/kit/assets/*",
    "./kit/stores":       "./src/kit/stores.js",
    "./kit/api":          "./src/kit/api.js",
    "./kit/router":       "./src/kit/router/index.js"
  },
  "workspaces": ["demo", "demo-kit"],
  "files": [
    "index.js",
    "src"
  ],
  "scripts": {
    "dev": "vite --config demo/vite.config.js --host 0.0.0.0 --port 5173",
    "build": "vite build --config demo/vite.config.js",
    "preview": "vite preview --config demo/vite.config.js --host 0.0.0.0 --port 4173",
    "demo": "npm run dev",
    "demo:build": "npm run build",
    "demo:preview": "npm run preview",
    "kit": "vite --config demo-kit/vite.config.js --host 0.0.0.0 --port 5174",
    "kit:build": "vite build --config demo-kit/vite.config.js",
    "kit:preview": "vite preview --config demo-kit/vite.config.js --host 0.0.0.0 --port 4174",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "svelte",
    "svelte5",
    "preprocessor",
    "css",
    "styling"
  ],
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "svelte": "*",
    "@iconify/svelte": "*",
    "trap-focus-svelte": "*",
    "@zerodevx/svelte-toast": "*"
  },
  "peerDependenciesMeta": {
    "@iconify/svelte": { "optional": true },
    "trap-focus-svelte": { "optional": true },
    "@zerodevx/svelte-toast": { "optional": true }
  },
  "dependencies": {
    "chalk": "*",
    "estree-walker": "*",
    "loglevel": "*",
    "magic-string": "*",
    "marked": "*",
    "postcss-selector-parser": "*"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "*",
    "@iconify-icons/mdi": "*",
    "@iconify-icons/ph": "*",
    "@iconify/icons-ph": "*",
    "@iconify/svelte": "*",
    "@sveltejs/vite-plugin-svelte": "*",
    "chokidar": "*",
    "postcss-nested": "*",
    "svelte": "*",
    "svelte-preprocess": "*",
    "vite": "*"
  }
}
