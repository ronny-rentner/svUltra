{
  "name": "svUltra",
  "version": "0.0.1-alpha",
  "description": "Svelte 5 preprocessors for consistent component styling and syntax sugar",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./snippet": "./src/snippet.svelte.js"
  },
  "files": [
    "index.js",
    "src"
  ],
  "scripts": {
    "dev": "vite --config demo/vite.config.js --host 0.0.0.0 --port 5173",
    "build": "vite build --config demo/vite.config.js",
    "preview": "vite preview --config demo/vite.config.js --host 0.0.0.0 --port 4173",
    "demo": "npm run dev",
    "demo:build": "npm run build",
    "demo:preview": "npm run preview",
    "test": "node --test test/*.test.js"
  },
  "keywords": [
    "svelte",
    "svelte5",
    "preprocessor",
    "css",
    "styling"
  ],
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "svelte": "*"
  },
  "dependencies": {
    "chalk": "*",
    "estree-walker": "*",
    "loglevel": "*",
    "magic-string": "*",
    "marked": "*",
    "postcss-selector-parser": "*"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "*",
    "@iconify-icons/mdi": "*",
    "@iconify-icons/ph": "*",
    "@iconify/icons-ph": "*",
    "@iconify/svelte": "*",
    "@sveltejs/vite-plugin-svelte": "*",
    "chokidar": "*",
    "svelte": "*",
    "svelte-preprocess": "*",
    "vite": "*"
  }
}
